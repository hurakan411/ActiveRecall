            "value": "Total Study"
          }
        }
      }
    },
    "学習を始める": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start Learning"
          }
        }
      }
    },
    "新しい教材を登録して学習": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Register New Material"
          }
        }
      }
    },
    "写真や動画から教材を登録して学習": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Study by registering materials from photos or videos."
          }
        }
      }
    },
    "登録済みの教材を選択して学習": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Study Existing Materials"
          }
        }
      }
    },
    "ライブラリから教材を選んで復習": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Review by selecting materials from your library."
          }
        }
      }
    },
    "ランダムに復習": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Random Review"
          }
        }
      }
    },
    "最近の教材": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recent Materials"
          }
        }
      }
    },
    "最高 %lld点": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "High Score: %lld pts"
          }
        }
      }
    },
    "%lld回学習": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Studied %lld times"
          }
        }
      }
    },
    "学習に役立つヒントが毎日届きます。\nモチベーションを高めましょう！": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Daily tips to help you learn.\nKeep your motivation high!"
          }
        }
      }
    },
    "学習の進捗がひと目でわかります。\n毎日のリコール回数を増やしましょう！": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "See your progress at a glance.\nIncrease your daily recall count!"
          }
        }
      }
    },
    "ここから教材の登録・アクティブリコールができます。\nマイク入力やカメラからAIで自動生成もできる！": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Register materials and start Active Recall here.\nYou can also auto-generate using AI from the camera or microphone!"
          }
        }
      }
    },
    "ACTIVE RECALL": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ACTIVE RECALL"
          }
        }
      }
    },
    "この教材の内容を記憶から呼び起こし、\nできるだけ詳しく書き出してください。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recall the contents of this material from memory\nand write it out in as much detail as possible."
          }
        }
      }
    },
    "入力": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Input"
          }
        }
      }
    },
    "全削除": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete All"
          }
        }
      }
    },
    "%lld 文字": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld chars"
          }
        }
      }
    },
    "学習したキーワードや概念、流れなどを\n思い出して自由に書き出しましょう...": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recall the keywords, concepts, and flow you learned\nand write freely..."
          }
        }
      }
    },
