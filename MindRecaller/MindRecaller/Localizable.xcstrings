    "新しい教材を登録して学習": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Register New Material"
          }
        }
      }
    },
    "写真や動画から教材を登録して学習": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Study by registering materials from photos or videos."
          }
        }
      }
    },
    "登録済みの教材を選択して学習": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Study Existing Materials"
