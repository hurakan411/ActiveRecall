      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Search Materials"
          }
        }
      }
    },
    "「%@」を削除しますか？学習ログも全て削除されます。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete \"%@\"? All study logs will also be deleted."
          }
        }
      }
    },
